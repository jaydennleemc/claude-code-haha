# Anthropic API 配置（二选一）
ANTHROPIC_API_KEY=sk-ant-xxx
# ANTHROPIC_AUTH_TOKEN=sk-xxx

# 自定义端点（默认 Anthropic 官方；可指向任何兼容 Anthropic Messages API 的服务）
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# 默认模型
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# 上下文窗口配置
CONTEXT_WINDOW=200000
COMPACT_THRESHOLD=0.8  # 达到窗口的 80% 时触发压缩

# Agent 循环配置
MAX_AGENT_TURNS=50
MAX_TOOL_PARALLEL=5

# 工具权限: 逗号分隔的允许规则
# 格式: tool_name[:pattern]
# ALLOWED_TOOLS=Read,Write,Bash:git *
# 留空则全部需要确认
ALLOWED_TOOLS=

# Skills 目录（相对于工作目录）
SKILLS_DIR=.claude/skills

# MCP 服务器配置（JSON 数组）
# 格式: [{"name": "...", "command": "...", "args": [...], "env": {...}}]
MCP_SERVERS=
